# =============================================================================
# ardouraAI — Environment Variables  (.env.template)
# Copy this file to .env and fill in your real values.
# NEVER commit the populated .env to source control — it is in .gitignore.
# =============================================================================

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# ── GitHub (shared token) ─────────────────────────────────────────────────────
GITHUB_TOKEN=github_pat_YOUR_TOKEN_HERE

# APPLICATION GitHub — the repo the agent acts ON (e.g. Princetondawgs).
# DO NOT point these at the ardouraAI repo (the agent code itself).
APP_GITHUB_OWNER=ashishPropt
APP_GITHUB_REPO=Princetondawgs
APP_GITHUB_BRANCH=main

# Legacy aliases — kept for scripts that still reference the old names.
# These should mirror APP_GITHUB_* above.
GITHUB_OWNER=ashishPropt
GITHUB_REPO=Princetondawgs
GITHUB_BRANCH=main

# ── Atlassian (Jira + Confluence) ─────────────────────────────────────────────
ATLASSIAN_BASE=https://proptxchange.atlassian.net
ATLASSIAN_EMAIL=your@email.com
ATLASSIAN_API_TOKEN=ATATT3x_YOUR_TOKEN_HERE

# ── Jira ──────────────────────────────────────────────────────────────────────
# Source project — tickets created here trigger the AI agent
JIRA_SOURCE_PROJECT_KEY=ADEV

# Approval/action project — AI agent creates tickets here
JIRA_ACTION_PROJECT_KEY=ACR

# ── Confluence ────────────────────────────────────────────────────────────────
# Page IDs for the two documentation pages the agent reads
CONFLUENCE_DOC_PAGE_ID=5996545
CONFLUENCE_TROUBLESHOOT_PAGE_ID=6160385

# Space key — used when writing back to Confluence (AI-discovered knowledge,
# changelog entries, etc.).
# Personal space key format: ~<accountId>  (find yours in Atlassian profile URL)
CONFLUENCE_SPACE_KEY=~YOUR_ACCOUNT_ID_HERE

# Page titles used by GenerateDocsfromGit_mcp.py when publishing docs
CONFLUENCE_DOC_PAGE_TITLE=Princetondawgs Documentation
CONFLUENCE_TROUBLESHOOT_PAGE_TITLE=Princetondawgs Troubleshooting Guide

# Confluence base URL (wiki subdomain)
CONFLUENCE_BASE_URL=https://proptxchange.atlassian.net/wiki

# ── Kafka (kafka_jira_producer.py / kafka_jira_consumer.py) ───────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=jira-events
KAFKA_GROUP_ID=jira-agent-group
KAFKA_TARGET_PROJECT_KEY=ADEV
KAFKA_TARGET_WEBHOOK_EVENT=jira:issue_created

# ── Flask (kafka_jira_producer.py webhook server) ─────────────────────────────
FLASK_PORT=5000
