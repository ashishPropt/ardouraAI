# =============================================================================
# ardouraAI — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit the populated .env to source control.
# =============================================================================

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=github_pat_YOUR_TOKEN_HERE
GITHUB_OWNER=ashishPropt
GITHUB_REPO=Princetondawgs
GITHUB_BRANCH=main

# ── Atlassian (Jira + Confluence) ─────────────────────────────────────────────
ATLASSIAN_BASE=https://proptxchange.atlassian.net
ATLASSIAN_EMAIL=ashish@proptxchange.com
ATLASSIAN_API_TOKEN=ATATT3x_YOUR_TOKEN_HERE

# ── Jira ──────────────────────────────────────────────────────────────────────
# Source project — tickets created here trigger the AI agent
JIRA_SOURCE_PROJECT_KEY=ADEV

# Approval/action project — AI agent creates tickets here
JIRA_ACTION_PROJECT_KEY=ACR

# ── Confluence ────────────────────────────────────────────────────────────────
# Page IDs for the two documentation pages the agent reads
CONFLUENCE_DOC_PAGE_ID=5996545
CONFLUENCE_TROUBLESHOOT_PAGE_ID=6160385

# Space key and page titles used by GenerateDocsfromGit_mcp.py
CONFLUENCE_SPACE_KEY=~7120207f8be028cbb84bc294e4ddd29895033d
CONFLUENCE_DOC_PAGE_TITLE=Princetondawgs Documentation
CONFLUENCE_TROUBLESHOOT_PAGE_TITLE=Princetondawgs Troubleshooting Guide

# ── Kafka (kafka_jira_producer.py / kafka_jira_consumer.py) ───────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=jira-events
KAFKA_GROUP_ID=jira-agent-group
